generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Release {
  id             String   @id @default(uuid())
  name           String
  targetDate     DateTime
  additionalInfo String?
  steps          String   @default("{}") // Stores stringified JSON
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
